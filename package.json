    "assets:decimate": "node tools/decimate-model.mjs"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/extensions": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@types/node": "^26.1.1",
    "@types/three": "^0.185.1",
    "meshoptimizer": "^1.2.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "three": "^0.185.1"
  }
}
